# Database
DB_HOST=127.0.0.1
DB_NAME=smartgarden
DB_USER=root
DB_PASS=

# Admin Panel
ADMIN_USER=admin
ADMIN_PASS=password123

# API Key (untuk ESP32 kirim data)
API_KEY=ganti_dengan_random_string

# MQTT WebSocket URL untuk koneksi publik (non-lokal)
# Lokal (LAN/localhost) otomatis pakai ws://<host>:9002 — tidak perlu diisi
# Isi ini hanya jika deploy ke server publik, contoh: wss://mqtt.yourdomain.com
MQTT_WS_URL=wss://mqtt.yourdomain.com
