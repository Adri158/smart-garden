# ─── API Base URL ────────────────────────────────────────────────────────────
# Lokal: kosongkan (Vite proxy otomatis forward /api → localhost:3000)
VITE_API_BASE=
# Publik: isi URL API server kamu
# VITE_API_BASE=https://api.domainkamu.com

# ─── MQTT WebSocket URL ───────────────────────────────────────────────────────
# Lokal: gunakan ws:// (tanpa SSL)
# VITE_MQTT_URL=ws://localhost:9002
# Publik: gunakan wss:// (dengan SSL)
VITE_MQTT_URL=wss://mqtt.domainkamu.com

# ─── API Key ─────────────────────────────────────────────────────────────────
# Harus sama dengan API_KEY di .env root
VITE_API_KEY=
