# ─── Database ────────────────────────────────────────────────────────────────
# Gunakan 127.0.0.1 bukan localhost (paksa TCP, hindari Unix socket)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smartgarden
DB_USER=root
DB_PASS=

# ─── API Key ─────────────────────────────────────────────────────────────────
# Harus sama dengan API_KEY di .env root
API_KEY=

# ─── OpenAI (untuk HelpWidget AI chat) ───────────────────────────────────────
OPENAI_API_KEY=

# ─── MQTT Broker ─────────────────────────────────────────────────────────────
# Lokal: localhost
# MQTT_HOST=localhost
# Publik: hostname broker kamu
# MQTT_HOST=mqtt.domainkamu.com
MQTT_HOST=localhost
MQTT_PORT=1883
