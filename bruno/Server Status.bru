meta {
  name: Server Status
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/server_status.php
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("has cpu_pct field", function() {
    expect(res.getBody().cpu_pct).to.be.a('number');
  });
}
