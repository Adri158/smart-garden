meta {
  name: Device Sensors Latest
  type: http
  seq: 8
}

get {
  url: {{apiUrl}}/api/devices/{{deviceId}}/sensors/latest
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("has device_id", function() {
    expect(res.getBody().data.device_id).to.be.a('string');
  });
  test("has soil field", function() {
    expect(res.getBody().data).to.have.property('soil');
  });
}
