meta {
  name: Sensor History
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/sensor_history.php?range=1h&sensor=soil&device={{deviceId}}
  body: none
  auth: none
}

params:query {
  range: 1h
  sensor: soil
  device: {{deviceId}}
}

headers {
  Accept: application/json
}

docs {
  range: 1h | 6h | 24h | 7d | 1m
  sensor: soil | temp_dht | temp_ds | humidity
  device: device_id dari tabel devices (lihat env)
}
