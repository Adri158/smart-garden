meta {
  name: Schedules PUT
  type: http
  seq: 16
}

put {
  url: {{apiUrl}}/api/schedules/1
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "enabled": false
  }
}

docs {
  Update any combination of: days, time, enabled.
  Change :id in URL to target a specific schedule.
  Requires X-API-Key header.
}

tests {
  test("status 200 or 404", function() {
    expect([200, 404]).to.include(res.getStatus());
  });
}
