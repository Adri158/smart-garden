meta {
  name: Device Detail
  type: http
  seq: 7
}

get {
  url: {{apiUrl}}/api/devices/{{deviceId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("has device_id", function() {
    expect(res.getBody().data.device_id).to.be.a('string');
  });
  test("has latest reading", function() {
    expect(res.getBody().data).to.have.property('latest');
  });
}
