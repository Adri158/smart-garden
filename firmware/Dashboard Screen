@Composable
fun DashboardScreen(
    state: DashboardState,
    onPumpClick: () -> Unit,
    onModeClick: () -> Unit,
    onSendCommand: (String) -> Unit
) {

    var commandText by remember { mutableStateOf("") }

    Box(
        modifier = Modifier
            .fillMaxSize()
            .background(
                Brush.verticalGradient(
                    colors = listOf(
                        Color(0xFF020617),
                        Color(0xFF0F1F3D)
                    )
                )
            )
    ) {

        Column(
            modifier = Modifier
                .fillMaxSize()
                .verticalScroll(rememberScrollState())
                .padding(20.dp)
        ) {

            StatusCard(state)

            Spacer(modifier = Modifier.height(20.dp))

            SensorGrid(state)

            Spacer(modifier = Modifier.height(20.dp))

            ControlSection(
                state = state,
                onPumpClick = onPumpClick,
                onModeClick = onModeClick
            )

            Spacer(modifier = Modifier.height(20.dp))

            TerminalSection(
                logs = state.logs,
                commandText = commandText,
                onCommandChange = { commandText = it },
                onSend = {
                    if (commandText.isNotBlank()) {
                        onSendCommand(commandText)
                        commandText = ""
                    }
                }
            )
        }
    }
}

/* ===================================================== */
/* ====================== STATUS ======================== */
/* ===================================================== */

@Composable
fun StatusCard(state: DashboardState) {

    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color(0xFF0B1220)
        ),
        shape = RoundedCornerShape(20.dp),
        modifier = Modifier.fillMaxWidth()
    ) {

        Column(
            modifier = Modifier.padding(20.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {

            Text(
                "ESP32 STATUS",
                color = Color(0xFF94A3B8),
                fontSize = 14.sp
            )

            Spacer(modifier = Modifier.height(12.dp))

            Text(
                text = if (state.relayOn) "ONLINE" else "OFFLINE",
                color = if (state.relayOn)
                    Color(0xFF22C55E)
                else
                    Color(0xFFEF4444),
                fontSize = 20.sp,
                fontWeight = FontWeight.Bold
            )
        }
    }
}

/* ===================================================== */
/* ====================== SENSORS ======================= */
/* ===================================================== */

@Composable
fun SensorGrid(state: DashboardState) {

    Column {

        Row(horizontalArrangement = Arrangement.spacedBy(12.dp)) {
            SensorCard("Temp Udara", state.tempAir, Modifier.weight(1f))
            SensorCard("Humidity", state.humidity, Modifier.weight(1f))
        }

        Spacer(modifier = Modifier.height(12.dp))

        Row(horizontalArrangement = Arrangement.spacedBy(12.dp)) {
            SensorCard("Temp Air", state.tempWater, Modifier.weight(1f))
            SoilCard(state.soil, Modifier.weight(1f))
        }
    }
}

@Composable
fun SensorCard(title: String, value: String, modifier: Modifier) {

    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color(0xFF0B1220)
        ),
        shape = RoundedCornerShape(20.dp),
        modifier = modifier
    ) {
        Column(
            modifier = Modifier.padding(20.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Text(title, color = Color(0xFF94A3B8))
            Spacer(modifier = Modifier.height(8.dp))
            Text(
                value,
                fontSize = 22.sp,
                fontWeight = FontWeight.Bold,
                color = Color.White
            )
        }
    }
}

@Composable
fun SoilCard(value: Int, modifier: Modifier) {

    val safeValue = value.coerceIn(0, 100)

    val animatedProgress by animateFloatAsState(
        targetValue = safeValue / 100f,
        animationSpec = tween(
            durationMillis = 700,
            easing = FastOutSlowInEasing
        ),
        label = "soilProgress"
    )

    val soilColor by animateColorAsState(
        targetValue =
            if (safeValue < 30) Color(0xFFEF4444)
            else if (safeValue < 60) Color(0xFFFACC15)
            else Color(0xFF22C55E),
        animationSpec = tween(600),
        label = "soilColor"
    )

    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color(0xFF0B1220)
        ),
        shape = RoundedCornerShape(20.dp),
        modifier = modifier
    ) {

        Column(
            modifier = Modifier.padding(20.dp)
        ) {

            Text("Soil Moisture", color = Color(0xFF94A3B8))

            Spacer(modifier = Modifier.height(12.dp))

            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .height(20.dp)
                    .background(Color.DarkGray, RoundedCornerShape(10.dp))
            ) {

                Box(
                    modifier = Modifier
                        .fillMaxWidth(animatedProgress)
                        .fillMaxHeight()
                        .background(
                            soilColor,
                            RoundedCornerShape(10.dp)
                        )
                )
            }

            Spacer(modifier = Modifier.height(8.dp))

            Text(
                "$safeValue %",
                fontWeight = FontWeight.Bold,
                color = Color.White
            )
        }
    }
}

/* ===================================================== */
/* ====================== CONTROL ======================= */
/* ===================================================== */

@Composable
fun ControlSection(
    state: DashboardState,
    onPumpClick: () -> Unit,
    onModeClick: () -> Unit
) {

    Row(horizontalArrangement = Arrangement.spacedBy(12.dp)) {

        Button(
            onClick = onPumpClick,
            modifier = Modifier.weight(1f),
            colors = ButtonDefaults.buttonColors(
                containerColor =
                    if (state.relayOn)
                        Color(0xFF22C55E)
                    else
                        Color(0xFFEF4444)
            )
        ) {
            Text(if (state.relayOn) "PUMP ON" else "PUMP OFF")
        }

        Button(
            onClick = onModeClick,
            modifier = Modifier.weight(1f)
        ) {
            Text(if (state.modeAuto) "AUTO" else "MANUAL")
        }
    }
}

/* ===================================================== */
/* ====================== TERMINAL ====================== */
/* ===================================================== */

@Composable
fun TerminalSection(
    logs: List<String>,
    commandText: String,
    onCommandChange: (String) -> Unit,
    onSend: () -> Unit
) {

    Card(
        colors = CardDefaults.cardColors(
            containerColor = Color(0xFF0B1220)
        ),
        shape = RoundedCornerShape(20.dp),
        modifier = Modifier.fillMaxWidth()
    ) {

        Column(
            modifier = Modifier.padding(20.dp)
        ) {

            Text("Terminal", color = Color(0xFF94A3B8))

            Spacer(modifier = Modifier.height(12.dp))

            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .height(160.dp)
                    .background(Color.Black)
                    .padding(8.dp)
                    .verticalScroll(rememberScrollState())
            ) {
                logs.takeLast(20).forEach {
                    Text(
                        text = it,
                        color = Color(0xFF22C55E),
                        fontSize = 12.sp
                    )
                }
            }

            Spacer(modifier = Modifier.height(12.dp))

            Row {

                TextField(
                    value = commandText,
                    onValueChange = onCommandChange,
                    modifier = Modifier.weight(1f),
                    singleLine = true
                )

                Spacer(modifier = Modifier.width(8.dp))

                Button(onClick = onSend) {
                    Text("Send")
                }
            }
        }
    }
}