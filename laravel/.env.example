APP_NAME="Smart Garden"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Lokal: http://localhost:8000
# Publik: https://domainkamu.com
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database (MariaDB/MySQL) ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smartgarden
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache & Session ─────────────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ─── OpenAI (untuk HelpWidget AI chat) ───────────────────────────────────────
OPENAI_API_KEY=

# ─── API Key ─────────────────────────────────────────────────────────────────
# Harus sama dengan API_KEY di .env root
API_KEY=
